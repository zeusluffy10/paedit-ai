{
  "expo": {
    "name": "Photo Motion AI",
    "slug": "photo-motion-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF8F2"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.photomotionai"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF8F2"
      },
      "package": "com.example.photomotionai"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Photo Motion AI to access your photos so you can create videos."
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "http://127.0.0.1:8000"
    }
  }
}
